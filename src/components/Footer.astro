---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

interface Props {
	settings: CollectionEntry<'settings'>['data'];
}

const { settings } = Astro.props;
const [siteFirst, siteMid, siteLast] = settings.siteName.split('.');
const year = new Date().getFullYear();
---

<footer id="contact" class="jp-footer">
	<div class="jp-footer-inner">
		<div class="jp-foot-grid">
			<div>
				<a href="/" class="jp-brand" aria-label={`${settings.siteName} — home`}>
					<span class="jp-brand-mark">{settings.brandInitials}</span>
					<span class="jp-brand-name">
						{siteFirst}<span class="jp-dot">.</span>{siteMid}<span class="jp-dot">.</span>{siteLast}
					</span>
				</a>
				<p class="jp-tagline">{settings.tagline}</p>
			</div>

			<div>
				<p class="jp-col-label">Navigation</p>
				<nav>
					{
						settings.nav.map((item) => (
							<a href={item.href} class="jp-nav-link">
								{item.label}
							</a>
						))
					}
				</nav>
			</div>

			<div class="jp-contact-col">
				<p class="jp-col-label">Contact</p>
				<div class="jp-contact-list">
					<a href={`tel:${settings.phone.replace(/\s+/g, '')}`} class="jp-contact-link">
						<Icon name="lucide:phone" class="jp-contact-icon" />
						<span class="jp-visually-hidden">Phone:</span>
						{settings.phone}
					</a>
					<a href={`mailto:${settings.email}`} class="jp-contact-link">
						<Icon name="lucide:mail" class="jp-contact-icon" />
						<span class="jp-visually-hidden">Email:</span>
						{settings.email}
					</a>
					<a
						href={settings.instagramUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="jp-contact-link"
					>
						<Icon name="simple-icons:instagram" class="jp-contact-icon" />
						<span class="jp-visually-hidden">Instagram:</span>
						{settings.instagramHandle}
					</a>
					<a
						href={settings.linkedinUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="jp-contact-link"
					>
						<Icon name="simple-icons:linkedin" class="jp-contact-icon" />
						<span class="jp-visually-hidden">LinkedIn:</span>
						{settings.linkedinHandle}
					</a>
				</div>
			</div>
		</div>

		<div class="jp-footer-bottom">
			<span>© {year} {settings.copyrightName} · {settings.title} · {settings.location}</span>
			<span>{settings.credentialLine}</span>
		</div>
	</div>
</footer>

<style>
	.jp-footer {
		background: #26221f;
		color: #e9e3d9;
	}

	.jp-footer-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: clamp(44px, 6vw, 72px) 20px clamp(28px, 4vw, 40px);
	}

	.jp-foot-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr;
		gap: clamp(28px, 5vw, 56px);
	}

	.jp-brand {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 14px;
		width: fit-content;
		text-decoration: none;
		color: inherit;
		transition: color 0.15s;
	}

	.jp-brand:hover {
		color: #a9d2cb;
	}

	.jp-brand:hover .jp-brand-mark {
		border-color: #a9d2cb;
	}

	.jp-brand-mark {
		width: 36px;
		height: 36px;
		border-radius: 9px;
		border: 1.5px solid #7fb3ab;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #a9d2cb;
		font-family: var(--heading-font);
		font-size: 18px;
	}

	.jp-brand-name {
		font-weight: 600;
		font-size: 17px;
	}

	.jp-dot {
		color: #8c857a;
	}

	.jp-tagline {
		font-family: var(--heading-font);
		font-style: italic;
		font-size: 16px;
		color: #b8b0a2;
		margin: 0;
		/* Three sentences that would otherwise drop "function." alone on a
		   fourth line — let the browser even the lines instead. */
		text-wrap: balance;
		max-width: 24em;
	}

	.jp-col-label {
		font-family: ui-monospace, monospace;
		font-size: 11px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #8c857a;
		margin: 0 0 16px;
	}

	nav {
		display: flex;
		flex-direction: column;
		gap: 11px;
	}

	.jp-nav-link {
		text-decoration: none;
		color: #e9e3d9;
		font-size: 15px;
		width: fit-content;
		transition: color 0.15s;
	}

	.jp-nav-link:hover {
		color: #a9d2cb;
	}

	/* Padding is cancelled by an equal negative margin so the bloom panel has
	   room to sit behind the column without nudging the grid. */
	.jp-contact-col {
		padding: 18px 20px;
		margin: -18px -20px;
		border-radius: 14px;
	}

	.jp-contact-list {
		display: flex;
		flex-direction: column;
		gap: 13px;
	}

	.jp-contact-link {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: #e9e3d9;
		font-size: 15px;
		transition: color 0.15s;
	}

	.jp-contact-link:hover {
		color: #a9d2cb;
	}

	/* Monochrome by design: all four icons inherit the link colour so the
	   brand marks sit in the footer's muted palette instead of fighting it. */
	.jp-contact-icon {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
		color: #b8b0a2;
		transition: color 0.15s;
	}

	/* The footer's dark-surface expression of the teal accent — `--accent`
	   (#3a7d76) is tuned for the cream bg and reads as a dim on #26221f. */
	.jp-contact-link:hover .jp-contact-icon {
		color: #a9d2cb;
	}

	.jp-visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip-path: inset(50%);
		white-space: nowrap;
		border: 0;
	}

	/* Arriving from a "get in touch" CTA: the column blooms in the footer's
	   light-teal and the label warms to the accent. Colour only — nothing
	   moves. Slow and soft on purpose, a nudge rather than a flash. */
	@keyframes jpContactBloom {
		0% {
			background: rgba(127, 179, 171, 0);
			box-shadow: inset 0 0 0 1px rgba(169, 210, 203, 0);
		}
		16% {
			background: rgba(127, 179, 171, 0.13);
			box-shadow: inset 0 0 0 1px rgba(169, 210, 203, 0.32);
		}
		68% {
			background: rgba(127, 179, 171, 0.13);
			box-shadow: inset 0 0 0 1px rgba(169, 210, 203, 0.32);
		}
		100% {
			background: rgba(127, 179, 171, 0);
			box-shadow: inset 0 0 0 1px rgba(169, 210, 203, 0);
		}
	}

	@keyframes jpContactLabel {
		0%,
		100% {
			color: #8c857a;
		}
		16%,
		68% {
			color: #a9d2cb;
		}
	}

	.jp-contact-pulse {
		animation: jpContactBloom 2.4s ease-in-out both;
	}

	.jp-contact-pulse .jp-col-label {
		animation: jpContactLabel 2.4s ease-in-out both;
	}

	.jp-footer-bottom {
		border-top: 1px solid #3a342f;
		margin-top: clamp(32px, 5vw, 52px);
		padding-top: 22px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: space-between;
		font-size: 13px;
		color: #8c857a;
	}
</style>

<script>
	// Any "#contact" CTA scrolls here; the pulse fires once the column is
	// actually on screen so the cue isn't spent while the page is still moving.
	const column = document.querySelector<HTMLElement>('.jp-contact-col');

	if (column) {
		const PULSE = 'jp-contact-pulse';
		let armed = false;

		function pulse() {
			column!.classList.remove(PULSE);
			void column!.offsetWidth; // reflow, so a repeat click replays it
			column!.classList.add(PULSE);
		}

		function arm() {
			if (armed) return;
			armed = true;

			const observer = new IntersectionObserver(
				(entries) => {
					if (!entries[0].isIntersecting) return;
					observer.disconnect();
					armed = false;
					pulse();
				},
				{ threshold: 0.6 }
			);
			observer.observe(column!);
		}

		document.addEventListener('click', (event) => {
			const link = (event.target as Element | null)?.closest?.('a[href$="#contact"]');
			if (link) arm();
		});

		// Covers cross-page links (/#contact) and back/forward navigation.
		window.addEventListener('hashchange', () => {
			if (location.hash === '#contact') arm();
		});

		if (location.hash === '#contact') arm();
	}
</script>
