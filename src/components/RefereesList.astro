---
import type { CollectionEntry } from 'astro:content';

interface Props {
	copy: CollectionEntry<'referencesPage'>['data']['referees'];
	items: CollectionEntry<'referees'>[];
}

const { copy, items } = Astro.props;
const sorted = [...items].sort((a, b) => a.data.order - b.data.order);
---

<section class="jp-referees">
	<div class="jp-referees-inner">
		<p class="jp-eyebrow">{copy.eyebrow}</p>
		<h2>{copy.heading}</h2>
		<div class="jp-referees-list">
			{
				sorted.map((referee) => (
					<div class="jp-referee-row">
						<span class="jp-initials">{referee.data.initials}</span>
						<div class="jp-referee-info">
							<span class="jp-referee-name">{referee.data.name}</span>
							<span class="jp-referee-role">{referee.data.role}</span>
							<span class="jp-referee-relation">{referee.data.relation}</span>
						</div>
					</div>
				))
			}
		</div>
		<p class="jp-note">{copy.note}</p>
	</div>
</section>

<style>
	.jp-referees {
		background: var(--beige);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.jp-referees-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: clamp(40px, 6vw, 72px) 20px;
	}

	.jp-eyebrow {
		font-family: ui-monospace, monospace;
		font-size: 12px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 12px;
	}

	h2 {
		font-family: var(--heading-font);
		font-weight: 400;
		font-size: clamp(26px, 4vw, 36px);
		line-height: 1.1;
		letter-spacing: -0.01em;
		margin: 0 0 24px;
		max-width: 16em;
	}

	.jp-referees-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 16px;
		overflow: hidden;
		max-width: 760px;
	}

	.jp-referee-row {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 18px 22px;
		border-top: 1px solid var(--border);
	}

	.jp-initials {
		width: 40px;
		height: 40px;
		border-radius: 99px;
		background: #e3dccf;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--heading-font);
		font-size: 16px;
		color: var(--accent-deep);
		flex-shrink: 0;
	}

	.jp-referee-info {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 4px 10px;
	}

	.jp-referee-name {
		font-weight: 600;
		font-size: 15.5px;
	}

	.jp-referee-role {
		font-size: 14px;
		color: var(--muted);
	}

	.jp-referee-relation {
		font-size: 13px;
		color: var(--accent-deep);
		font-style: italic;
	}

	.jp-note {
		font-size: 14.5px;
		color: var(--muted);
		margin: 18px 0 0;
	}
</style>
