<dialog id="jp-cert-lightbox" class="jp-lightbox">
	<button type="button" class="jp-lightbox-close" data-close-lightbox aria-label="Close">✕</button>
	<div class="jp-lightbox-card">
		<div class="jp-lightbox-image">
			<img data-lightbox-image alt="" />
		</div>
		<div class="jp-lightbox-caption">
			<p class="jp-lightbox-title" data-lightbox-title></p>
			<p class="jp-lightbox-year" data-lightbox-year></p>
		</div>
	</div>
</dialog>

<style>
	.jp-lightbox {
		position: fixed;
		max-width: 560px;
		width: calc(100% - 48px);
		margin: auto;
		padding: 0;
		border: none;
		border-radius: 16px;
		background: transparent;
		overflow: visible;
	}

	.jp-lightbox::backdrop {
		background: rgba(38, 34, 31, 0.62);
		backdrop-filter: blur(4px);
	}

	.jp-lightbox-close {
		position: absolute;
		top: -14px;
		right: -14px;
		width: 40px;
		height: 40px;
		border-radius: 99px;
		border: 1px solid var(--border);
		background: var(--bg);
		color: var(--text);
		font-size: 19px;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 8px 20px -8px rgba(0, 0, 0, 0.4);
		transition: background 0.15s;
	}

	.jp-lightbox-close:hover {
		background: var(--beige);
	}

	.jp-lightbox-close:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.jp-lightbox-card {
		background: var(--bg);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 30px 80px -20px rgba(38, 34, 31, 0.6);
	}

	.jp-lightbox-image {
		display: flex;
		align-items: center;
		justify-content: center;
		max-height: 74vh;
	}

	.jp-lightbox-image img {
		display: block;
		width: auto;
		height: auto;
		max-width: 100%;
		max-height: 74vh;
		object-fit: contain;
	}

	.jp-lightbox-caption {
		padding: 16px 20px;
		border-top: 1px solid var(--border);
	}

	.jp-lightbox-title {
		margin: 0;
		font-family: var(--heading-font);
		font-size: 18px;
		color: var(--text);
	}

	.jp-lightbox-year {
		margin: 3px 0 0;
		font-family: ui-monospace, monospace;
		font-size: 12.5px;
		letter-spacing: 0.04em;
		color: var(--accent-deep);
	}
</style>

<script>
	const dialog = document.getElementById('jp-cert-lightbox') as HTMLDialogElement | null;
	if (dialog) {
		const titleEl = dialog.querySelector<HTMLElement>('[data-lightbox-title]');
		const yearEl = dialog.querySelector<HTMLElement>('[data-lightbox-year]');
		const imageEl = dialog.querySelector<HTMLImageElement>('[data-lightbox-image]');

		document.querySelectorAll<HTMLButtonElement>('[data-open-lightbox]').forEach((button) => {
			button.addEventListener('click', () => {
				if (titleEl) titleEl.textContent = button.dataset.certTitle ?? '';
				if (yearEl) yearEl.textContent = button.dataset.certYear ?? '';
				if (imageEl) {
					imageEl.src = button.dataset.certImage ?? '';
					imageEl.alt = button.dataset.certTitle ?? '';
					imageEl.style.objectPosition = button.dataset.certPosition ?? '50% 50%';
				}
				dialog.showModal();
			});
		});

		dialog.querySelectorAll<HTMLButtonElement>('[data-close-lightbox]').forEach((button) => {
			button.addEventListener('click', () => dialog.close());
		});

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});
	}
</script>
