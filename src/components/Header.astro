---
import type { CollectionEntry } from 'astro:content';

interface Props {
	settings: CollectionEntry<'settings'>['data'];
	currentPath?: string;
}

const { settings, currentPath = '/' } = Astro.props;
const [siteFirst, siteMid, siteLast] = settings.siteName.split('.');
const isHome = currentPath === '/';
const brandHref = isHome ? '#top' : '/';
---

<header class="jp-header">
	<div class="jp-header-inner">
		<a href={brandHref} class="jp-brand">
			<span class="jp-brand-mark">{settings.brandInitials}</span>
			<span class="jp-brand-name">
				{siteFirst}<span class="jp-dot">.</span>{siteMid}<span class="jp-dot">.</span>{siteLast}
			</span>
		</a>
		<nav>
			{
				settings.nav.map((item) => {
					const isCta = item.href === settings.contactCta.href;
					const isActive = !isCta && item.href === currentPath;
					if (isCta) {
						return (
							<a href={item.href} class="jp-nav-cta">
								{item.label}
							</a>
						);
					}
					return (
						<a
							href={item.href}
							class:list={['jp-nav-link', isActive && 'jp-nav-link--active']}
							aria-current={isActive ? 'page' : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<style>
	.jp-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(250, 248, 244, 0.88);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	.jp-header-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 14px 20px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.jp-brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--text);
		cursor: pointer;
		transition: color 0.15s;
	}

	.jp-brand:hover {
		color: var(--accent);
	}

	.jp-brand:hover .jp-brand-mark {
		border-color: var(--accent-deep);
		color: var(--accent-deep);
	}

	.jp-brand-mark {
		width: 34px;
		height: 34px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent);
		font-family: var(--heading-font);
		font-size: 18px;
		flex-shrink: 0;
	}

	.jp-brand-name {
		font-weight: 600;
		letter-spacing: -0.01em;
		font-size: 16px;
	}

	.jp-dot {
		color: var(--muted);
	}

	nav {
		display: flex;
		align-items: center;
		gap: 4px;
		white-space: nowrap;
	}

	.jp-nav-link {
		text-decoration: none;
		color: var(--text);
		font-size: 14.5px;
		padding: 8px 12px;
		border-radius: 8px;
		transition:
			background 0.15s,
			color 0.15s;
	}

	.jp-nav-link:hover {
		background: var(--beige);
		color: var(--accent-deep);
	}

	.jp-nav-link--active {
		color: var(--accent-deep);
		font-weight: 600;
		background: var(--beige);
	}

	.jp-nav-cta {
		text-decoration: none;
		color: #fff;
		background: var(--accent);
		font-size: 14.5px;
		font-weight: 600;
		padding: 8px 16px;
		border-radius: 99px;
		transition: background 0.15s;
	}

	.jp-nav-cta:hover {
		background: var(--accent-deep);
	}
</style>
