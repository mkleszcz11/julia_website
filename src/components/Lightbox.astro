---
// Shared image lightbox. Any page that renders `[data-open-lightbox]` triggers
// (see CertificatesTimeline, GallerySection) mounts this once; the trigger's
// data-lb-* attributes supply the content, so this component stays copy-free.
interface Props {
	maxWidth?: string;
}

const { maxWidth = '560px' } = Astro.props;
---

<dialog id="jp-lightbox" class="jp-lightbox" style={{ maxWidth }}>
	<button type="button" class="jp-lightbox-close" data-close-lightbox aria-label="Close">✕</button>
	<div class="jp-lightbox-card">
		<div class="jp-lightbox-image">
			<img data-lightbox-image alt="" />
		</div>
		<div class="jp-lightbox-caption" data-lightbox-caption>
			<p class="jp-lightbox-title" data-lightbox-title></p>
			<p class="jp-lightbox-meta" data-lightbox-meta></p>
		</div>
	</div>
</dialog>

<style>
	.jp-lightbox {
		position: fixed;
		width: calc(100% - 48px);
		margin: auto;
		padding: 0;
		border: none;
		border-radius: 16px;
		background: transparent;
		overflow: visible;
	}

	.jp-lightbox::backdrop {
		background: rgba(38, 34, 31, 0.62);
		backdrop-filter: blur(4px);
	}

	.jp-lightbox-close {
		position: absolute;
		top: -14px;
		right: -14px;
		width: 40px;
		height: 40px;
		border-radius: 99px;
		border: 1px solid var(--border);
		background: var(--bg);
		color: var(--text);
		font-size: 19px;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 8px 20px -8px rgba(0, 0, 0, 0.4);
		transition: background 0.15s;
		z-index: 1;
	}

	.jp-lightbox-close:hover {
		background: var(--beige);
	}

	.jp-lightbox-close:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.jp-lightbox-card {
		background: var(--bg);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 30px 80px -20px rgba(38, 34, 31, 0.6);
	}

	.jp-lightbox-image {
		display: flex;
		align-items: center;
		justify-content: center;
		max-height: 74vh;
	}

	.jp-lightbox-image img {
		display: block;
		width: auto;
		height: auto;
		max-width: 100%;
		max-height: 74vh;
		object-fit: contain;
	}

	.jp-lightbox-caption {
		padding: 16px 20px;
		border-top: 1px solid var(--border);
	}

	.jp-lightbox-caption[hidden] {
		display: none;
	}

	.jp-lightbox-title {
		margin: 0;
		font-family: var(--heading-font);
		font-size: 18px;
		line-height: 1.3;
		color: var(--text);
	}

	.jp-lightbox-title:empty {
		display: none;
	}

	.jp-lightbox-meta {
		margin: 3px 0 0;
		font-family: ui-monospace, monospace;
		font-size: 12.5px;
		letter-spacing: 0.04em;
		color: var(--accent-deep);
	}

	.jp-lightbox-meta:empty {
		display: none;
	}
</style>

<script>
	const dialog = document.getElementById('jp-lightbox') as HTMLDialogElement | null;
	if (dialog) {
		const captionEl = dialog.querySelector<HTMLElement>('[data-lightbox-caption]');
		const titleEl = dialog.querySelector<HTMLElement>('[data-lightbox-title]');
		const metaEl = dialog.querySelector<HTMLElement>('[data-lightbox-meta]');
		const imageEl = dialog.querySelector<HTMLImageElement>('[data-lightbox-image]');

		document.querySelectorAll<HTMLButtonElement>('[data-open-lightbox]').forEach((button) => {
			button.addEventListener('click', () => {
				const title = button.dataset.lbTitle ?? '';
				const meta = button.dataset.lbMeta ?? '';
				if (titleEl) titleEl.textContent = title;
				if (metaEl) metaEl.textContent = meta;
				if (captionEl) captionEl.hidden = !title && !meta;
				if (imageEl) {
					imageEl.src = button.dataset.lbImage ?? '';
					imageEl.alt = button.dataset.lbAlt ?? title;
				}
				dialog.showModal();
			});
		});

		dialog.querySelectorAll<HTMLButtonElement>('[data-close-lightbox]').forEach((button) => {
			button.addEventListener('click', () => dialog.close());
		});

		// The dialog element itself is the backdrop hit area: the card sits inside
		// it, so a click landing on the dialog means "outside the image".
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});
	}
</script>
