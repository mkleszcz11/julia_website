---
import type { CollectionEntry } from 'astro:content';
import CoverImage from './CoverImage.astro';

interface Props {
	instagram: CollectionEntry<'home'>['data']['instagram'];
	instagramUrl: string;
	posts: CollectionEntry<'instagram'>[];
}

const { instagram, instagramUrl, posts } = Astro.props;
const sorted = [...posts].sort((a, b) => a.data.order - b.data.order);
---

<section id="instagram" class="jp-instagram">
	<div class="jp-instagram-header">
		<a href="#instagram" class="jp-instagram-brand">
			<span class="jp-instagram-icon">
				<span class="jp-instagram-icon-inner"></span>
			</span>
			<span class="jp-instagram-handle">{instagram.eyebrowHandle}</span>
		</a>
		<a href={instagramUrl} target="_blank" rel="noopener" class="jp-cta-outline">
			{instagram.ctaLabel} <span class="jp-arrow">→</span>
		</a>
	</div>
	<div class="jp-instagram-grid">
		{
			sorted.map((post) => (
				<a href={post.data.href ?? instagramUrl} target="_blank" rel="noopener" class="jp-instagram-tile">
					<CoverImage
						src={post.data.image}
						alt={post.data.alt}
						ratio="1 / 1"
						position={post.data.imagePosition ?? '50% 50%'}
						radius="12px"
					/>
				</a>
			))
		}
	</div>
</section>

<style>
	.jp-instagram {
		max-width: 1180px;
		margin: 0 auto;
		padding: clamp(48px, 7vw, 84px) 20px;
	}

	.jp-instagram-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		margin: 0 0 26px;
	}

	.jp-instagram-brand {
		display: flex;
		align-items: center;
		gap: 11px;
		text-decoration: none;
		color: var(--text);
	}

	.jp-instagram-icon {
		width: 38px;
		height: 38px;
		border-radius: 11px;
		background: linear-gradient(135deg, #feda75, #d62976 45%, #962fbf 75%, #4f5bd5);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.jp-instagram-icon-inner {
		width: 18px;
		height: 18px;
		border: 2px solid #fff;
		border-radius: 6px;
		position: relative;
	}

	.jp-instagram-icon-inner::after {
		content: '';
		position: absolute;
		inset: 3px;
		border: 2px solid #fff;
		border-radius: 99px;
	}

	.jp-instagram-handle {
		font-family: var(--heading-font);
		font-size: clamp(20px, 3vw, 26px);
	}

	.jp-cta-outline {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: var(--accent-deep);
		font-weight: 600;
		font-size: 15.5px;
		border: 1.5px solid var(--accent);
		padding: 11px 22px;
		border-radius: 99px;
		transition:
			background 0.15s,
			color 0.15s;
	}

	.jp-cta-outline:hover {
		background: var(--accent);
		color: #fff;
	}

	.jp-arrow {
		font-size: 17px;
	}

	.jp-instagram-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(8px, 1.4vw, 16px);
	}

	.jp-instagram-tile {
		display: block;
		text-decoration: none;
		transition: transform 0.15s;
	}

	.jp-instagram-tile:hover {
		transform: scale(1.02);
	}
</style>
