---
import type { CollectionEntry } from 'astro:content';
import TimelineRail from './TimelineRail.astro';
import TimelineDot from './TimelineDot.astro';

interface Props {
	copy: CollectionEntry<'about'>['data']['experience'];
	items: CollectionEntry<'experience'>[];
}

const { copy, items } = Astro.props;
const sorted = [...items].sort((a, b) => a.data.order - b.data.order);
---

<section class="jp-experience">
	<h2>{copy.heading}</h2>

	<TimelineRail>
		{
			sorted.map((entry) => (
				<li class="jp-experience-item">
					<TimelineDot special={entry.data.special} />
					<div class="jp-experience-content">
						<p class="jp-dates">{entry.data.dates}</p>
						<h3>{entry.data.employer}</h3>
						<p class="jp-role">{entry.data.role}</p>
						<p class="jp-desc">{entry.data.description}</p>
					</div>
				</li>
			))
		}
	</TimelineRail>
</section>

<style>
	.jp-experience {
		max-width: 1180px;
		margin: 0 auto;
		padding: clamp(44px, 6vw, 80px) 20px clamp(28px, 4vw, 44px);
	}

	h2 {
		font-family: var(--heading-font);
		font-weight: 400;
		font-size: clamp(30px, 4.6vw, 44px);
		line-height: 1.05;
		letter-spacing: -0.01em;
		margin: 0 0 30px;
	}

	.jp-experience-item {
		display: flex;
		align-items: flex-start;
		gap: clamp(14px, 2.4vw, 26px);
	}

	.jp-experience-content {
		flex: 1;
		min-width: 0;
		padding-bottom: 4px;
	}

	.jp-dates {
		font-family: ui-monospace, monospace;
		font-size: 13px;
		letter-spacing: 0.04em;
		color: var(--muted);
		margin: 0 0 5px;
	}

	h3 {
		font-family: var(--heading-font);
		font-weight: 600;
		font-size: clamp(20px, 2.6vw, 25px);
		line-height: 1.15;
		letter-spacing: -0.01em;
		margin: 0 0 5px;
		color: var(--text);
	}

	.jp-role {
		font-size: 15px;
		color: var(--muted);
		margin: 0 0 10px;
	}

	.jp-desc {
		font-size: 16px;
		color: var(--text);
		margin: 0;
		max-width: 44em;
	}
</style>
