---
interface Props {
	src: string;
	alt: string;
	ratio: string;
	position?: string;
	radius?: string;
	background?: string;
	borderColor?: string | false;
	shadow?: string;
	class?: string;
}

const {
	src,
	alt,
	ratio,
	position = '50% 50%',
	radius = '16px',
	background = 'var(--beige)',
	borderColor = 'var(--border)',
	shadow,
	class: className,
} = Astro.props;
---

<div
	class:list={['jp-cover', className]}
	style={{
		aspectRatio: ratio,
		borderRadius: radius,
		background,
		border: borderColor ? `1px solid ${borderColor}` : 'none',
		boxShadow: shadow,
	}}
>
	<img src={src} alt={alt} style={{ objectPosition: position }} />
</div>

<style>
	.jp-cover {
		position: relative;
		overflow: hidden;
	}

	.jp-cover img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
