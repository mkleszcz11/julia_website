---
import type { CollectionEntry } from 'astro:content';
import CoverImage from './CoverImage.astro';

interface Props {
	copy: CollectionEntry<'about'>['data']['gallery'];
	items: CollectionEntry<'galleryItems'>[];
}

const { copy, items } = Astro.props;
const sorted = [...items].sort((a, b) => a.data.order - b.data.order);
---

<section class="jp-gallery">
	<h2>{copy.heading}</h2>
	<p class="jp-intro">{copy.intro}</p>
	<div class="jp-gallery-grid">
		{
			sorted.map((item) => (
				<figure class="jp-gallery-item">
					<button
						type="button"
						class="jp-gallery-trigger"
						data-open-lightbox
						data-lb-title={item.data.caption}
						data-lb-image={item.data.image}
						data-lb-alt={item.data.imageAlt}
						aria-label={`Enlarge photo: ${item.data.caption}`}
					>
						<CoverImage
							src={item.data.image}
							alt={item.data.imageAlt}
							ratio="4 / 3"
							position={item.data.imagePosition ?? '50% 50%'}
							radius="14px"
						/>
						<span class="jp-gallery-enlarge" aria-hidden="true">⤢</span>
					</button>
					<figcaption>{item.data.caption}</figcaption>
				</figure>
			))
		}
	</div>
</section>

<style>
	.jp-gallery {
		max-width: 1180px;
		margin: 0 auto;
		padding: clamp(36px, 5vw, 64px) 20px clamp(44px, 6vw, 80px);
	}

	h2 {
		font-family: var(--heading-font);
		font-weight: 400;
		font-size: clamp(30px, 4.6vw, 44px);
		line-height: 1.05;
		letter-spacing: -0.01em;
		margin: 0 0 12px;
	}

	.jp-intro {
		font-size: 16px;
		color: var(--muted);
		margin: 0 0 30px;
		max-width: 40em;
	}

	.jp-gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: clamp(14px, 2vw, 22px);
	}

	.jp-gallery-item {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.jp-gallery-trigger {
		position: relative;
		display: block;
		width: 100%;
		padding: 0;
		border: none;
		background: none;
		border-radius: 14px;
		cursor: zoom-in;
		transition: transform 0.15s;
	}

	.jp-gallery-trigger:hover {
		transform: scale(1.015);
	}

	.jp-gallery-trigger:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	/* Discoverability cue — the cursor alone doesn't reach touch users. */
	.jp-gallery-enlarge {
		position: absolute;
		right: 10px;
		bottom: 10px;
		width: 30px;
		height: 30px;
		border-radius: 99px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		color: var(--text);
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 4px 12px -4px rgba(38, 34, 31, 0.5);
		opacity: 0.85;
		transition: opacity 0.15s;
	}

	.jp-gallery-trigger:hover .jp-gallery-enlarge {
		opacity: 1;
	}

	figcaption {
		font-size: 14.5px;
		color: var(--muted);
		line-height: 1.4;
	}
</style>
