---
import type { CollectionEntry } from 'astro:content';

interface Props {
	items: CollectionEntry<'references'>[];
}

const { items } = Astro.props;
const sorted = [...items].sort((a, b) => a.data.pageOrder - b.data.pageOrder);

const documentLabel = (doc: CollectionEntry<'references'>['data']['document']) =>
	doc.label ?? (doc.type === 'pdf' ? 'View full reference (PDF)' : 'View full reference');

// Roles that name a parent institution use a "…, University" clause. Break
// at that last comma so the university sits on its own line as a whole unit
// ("title · institute," / "University …") rather than orphaning a trailing
// word. Roles without a comma render on a single line.
const splitRole = (role: string) => {
	const idx = role.lastIndexOf(', ');
	if (idx === -1) return { primary: role, secondary: '' };
	return { primary: role.slice(0, idx + 1), secondary: role.slice(idx + 2) };
};
---

<section class="jp-endorsements">
	<div class="jp-endorsements-grid jp-refs-grid">
		{
			sorted.map((item) => (
				<figure class:list={['jp-endorsement-card', item.data.highlighted && 'jp-endorsement-card--highlighted']}>
					<blockquote>{item.data.longQuote}</blockquote>
					<figcaption>
						<span class="jp-name">{item.data.name}</span>
						{(() => {
							const { primary, secondary } = splitRole(item.data.role);
							return (
								<span class="jp-role">
									<span class="jp-role-primary">{primary}</span>
									{secondary && <span class="jp-role-secondary">{secondary}</span>}
								</span>
							);
						})()}
						{item.data.relation && <span class="jp-relation">{item.data.relation}</span>}
					</figcaption>
					<a
						class="jp-doc-link"
						href={item.data.document.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`${documentLabel(item.data.document)} from ${item.data.name}`}
					>
						<svg class="jp-doc-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path
								d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"
								stroke="currentColor"
								stroke-width="1.6"
								stroke-linejoin="round"
							/>
							<path d="M14 3v5h5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
						</svg>
						<span>{documentLabel(item.data.document)}</span>
						<span class="jp-doc-arrow" aria-hidden="true">→</span>
					</a>
				</figure>
			))
		}
	</div>
</section>

<style>
	.jp-endorsements {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 20px clamp(40px, 6vw, 64px);
	}

	.jp-endorsements-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 18px;
	}

	.jp-endorsement-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: clamp(22px, 3vw, 30px);
		margin: 0;
		display: flex;
		flex-direction: column;
		box-shadow: 0 10px 28px -22px rgba(44, 40, 36, 0.4);
	}

	/* Teal left-border quietly marks the text as a quotation, replacing
	   the old decorative glyph. */
	blockquote {
		margin: 0 0 22px;
		padding-left: 16px;
		border-left: 3px solid var(--accent);
		font-size: clamp(16px, 1.9vw, 17.5px);
		color: var(--text);
		line-height: 1.6;
		flex: 1;
	}

	/* Attribution is set apart by the divider above and its smaller muted
	   text alone; the single teal accent per card lives on the quote. */
	figcaption {
		display: flex;
		flex-direction: column;
		gap: 2px;
		border-top: 1px solid var(--border);
		padding: 18px 0 0;
	}

	.jp-name {
		font-weight: 600;
		font-size: 15px;
	}

	.jp-role {
		display: flex;
		flex-direction: column;
		font-size: 13.5px;
		color: var(--muted);
	}

	/* The university clause sits on its own line; `balance` keeps it from
	   orphaning a single trailing word if it too must wrap. */
	.jp-role-secondary {
		text-wrap: balance;
	}

	.jp-relation {
		font-size: 12.5px;
		color: var(--accent-deep);
		margin-top: 2px;
		font-style: italic;
	}

	.jp-doc-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		align-self: flex-start;
		margin-top: 18px;
		padding: 9px 16px;
		border: 1px solid var(--border);
		border-radius: 99px;
		background: var(--beige);
		color: var(--accent-deep);
		font-size: 13.5px;
		font-weight: 600;
		text-decoration: none;
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			transform 0.18s ease;
	}

	.jp-doc-link:hover {
		background: #e6f0ed;
		border-color: #cfe2dd;
		transform: translateY(-1px);
	}

	.jp-doc-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.jp-doc-icon {
		width: 17px;
		height: 17px;
		flex-shrink: 0;
	}

	.jp-doc-arrow {
		font-size: 14px;
		transition: transform 0.18s ease;
	}

	.jp-doc-link:hover .jp-doc-arrow {
		transform: translateX(2px);
	}

	@media (max-width: 760px) {
		.jp-refs-grid {
			grid-template-columns: 1fr !important;
		}
	}
</style>
