---
import type { CollectionEntry } from 'astro:content';

interface Props {
	items: CollectionEntry<'references'>[];
}

const { items } = Astro.props;
const sorted = [...items].sort((a, b) => a.data.pageOrder - b.data.pageOrder);
---

<section class="jp-endorsements">
	<div class="jp-endorsements-grid jp-refs-grid">
		{
			sorted.map((item) => (
				<figure class:list={['jp-endorsement-card', item.data.highlighted && 'jp-endorsement-card--highlighted']}>
					<span class="jp-quote-mark" aria-hidden="true">
						“
					</span>
					<blockquote>{item.data.longQuote ?? item.data.quote}</blockquote>
					<figcaption>
						<span class="jp-initials">{item.data.initials}</span>
						<span>
							<span class="jp-name">{item.data.name}</span>
							<span class="jp-role">{item.data.role}</span>
							{item.data.relation && <span class="jp-relation">{item.data.relation}</span>}
						</span>
					</figcaption>
				</figure>
			))
		}
	</div>
</section>

<style>
	.jp-endorsements {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 20px clamp(40px, 6vw, 64px);
	}

	.jp-endorsements-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 18px;
	}

	.jp-endorsement-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: clamp(22px, 3vw, 30px);
		margin: 0;
		display: flex;
		flex-direction: column;
		box-shadow: 0 10px 28px -22px rgba(44, 40, 36, 0.4);
	}

	.jp-endorsement-card--highlighted {
		background: #eef4f2;
		border-color: #cfe2dd;
	}

	.jp-quote-mark {
		font-family: var(--heading-font);
		font-size: 48px;
		line-height: 0.5;
		color: var(--accent);
		margin: 6px 0 12px;
	}

	blockquote {
		margin: 0 0 22px;
		font-size: clamp(16px, 1.9vw, 17.5px);
		color: var(--text);
		line-height: 1.6;
		flex: 1;
	}

	figcaption {
		display: flex;
		align-items: center;
		gap: 14px;
		border-top: 1px solid var(--border);
		padding-top: 18px;
	}

	.jp-initials {
		width: 46px;
		height: 46px;
		border-radius: 99px;
		background: #e3dccf;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--heading-font);
		font-size: 18px;
		color: var(--accent-deep);
		flex-shrink: 0;
	}

	.jp-name {
		display: block;
		font-weight: 600;
		font-size: 15px;
	}

	.jp-role {
		display: block;
		font-size: 13.5px;
		color: var(--muted);
	}

	.jp-relation {
		display: block;
		font-size: 12.5px;
		color: var(--accent-deep);
		margin-top: 2px;
		font-style: italic;
	}

	@media (max-width: 760px) {
		.jp-refs-grid {
			grid-template-columns: 1fr !important;
		}
	}
</style>
