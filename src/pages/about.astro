---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import AboutHero from '../components/AboutHero.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import EducationList from '../components/EducationList.astro';
import GallerySection from '../components/GallerySection.astro';
import ClosingCta from '../components/ClosingCta.astro';
import Footer from '../components/Footer.astro';

const settingsEntry = await getEntry('settings', 'settings');
const aboutEntry = await getEntry('about', 'about');
if (!settingsEntry || !aboutEntry) {
	throw new Error('Missing required singleton content entries: settings/about');
}
const settings = settingsEntry.data;
const about = aboutEntry.data;

const experienceItems = await getCollection('experience');
const educationItems = await getCollection('education');
const galleryItems = await getCollection('galleryItems');
---

<BaseLayout title="About Me — Julia Pilch, Physiotherapist" description={about.hero.intro[0]}>
	<Header settings={settings} currentPath="/about" />
	<main>
		<AboutHero hero={about.hero} />
		<ExperienceTimeline copy={about.experience} items={experienceItems} />
		<EducationList copy={about.education} items={educationItems} />
		<GallerySection copy={about.gallery} items={galleryItems} />
		<ClosingCta heading={about.closing.heading} ctaLabel={about.closing.ctaLabel} ctaHref={about.closing.ctaHref} variant="accentDeep" />
	</main>
	<Footer settings={settings} />
</BaseLayout>
